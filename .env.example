# Banco de dados (SQLite local — zero config)
DATABASE_URL="file:./dev.db"

# Modo mock: true = usa fixtures JSON, false = scraping real
USE_MOCK=false

# Agendamento cron (padrão: 08:00 Brasília = 11:00 UTC)
CRON_SCHEDULE="0 11 * * *"

# Rodar scraping ao iniciar o servidor?
SCRAPE_ON_START=true

# Credenciais Betfair (opcional — odds são públicas sem login)
BETFAIR_USER=""
BETFAIR_PASS=""

# Credenciais BetMGM (opcional)
BETMGM_USER=""
BETMGM_PASS=""

# Credenciais Superbet (opcional)
SUPERBET_USER=""
SUPERBET_PASS=""

# Proxy BR (opcional — necessário fora do Brasil)
# Formato: http://user:pass@host:port
PROXY_URL=""

# Pitaco API (cookie de sessão — necessário estar logado no site)
PITACO_SESSION_COOKIE=""

# Timeout do Playwright em ms
PLAYWRIGHT_TIMEOUT=45000

# Número de tentativas em caso de falha
SCRAPE_RETRIES=3

# ─── Scraper Python (nodriver) ───────────────────────────────────────────────
# URL inicial do site (Brasil). Use a home de futebol / copa do mundo.
BET365_TARGET_URL=https://www.bet365.com/#/AC/B18/C20604387/D48e/

# Endpoint do Next.js que recebe o JSON do scraper Python
NEXT_API_URL=http://localhost:3000/api/scrape/bet365

# Chave compartilhada — deve bater entre o .env do Next e o do Python
SCRAPE_SECRET=

# Proxy para o scraper Python (opcional — Bet365 pode bloquear IP)
# Formato: http://user:pass@host:port
BET365_PROXY=

# Headless no Python (não recomendado: Bet365 serve conteúdo degradado)
BET365_HEADLESS=false
